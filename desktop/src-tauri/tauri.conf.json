{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "OpenNivara",
	"version": "0.1.0-alpha.2",
	"identifier": "io.github.vatsalc26.opennivara",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "OpenNivara",
				"width": 1200,
				"height": 760,
				"minWidth": 960,
				"minHeight": 640,
				"decorations": false
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"resources": ["../../packs/builtin/**/*"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
